{
  "name": "dawn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm run generate",
    "dev": "concurrently -k -n next,inngest -c cyan,magenta \"next dev --turbopack\" \"pnpm run dev:inngest\"",
    "dev:inngest": "inngest-cli dev -u http://localhost:3000/api/inngest --log-level warn --poll-interval 30",
    "prebuild": "pnpm run generate",
    "build": "next build",
    "start": "next start",
    "generate": "node scripts/generate.mjs",
    "bootstrap": "node scripts/bootstrap.mjs",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local --schema public > src/lib/db/database.types.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.75",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "ai": "^6.0.175",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "inngest": "^4.3.0",
    "js-tiktoken": "^1.0.21",
    "kysely": "^0.28.17",
    "kysely-supabase": "^0.2.1",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "next": "16.2.5",
    "openai": "^6.37.0",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "happy-dom": "^20.9.0",
    "inngest-cli": "^1.19.1",
    "supabase": "^2.98.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}