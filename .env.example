# --- Supabase ---
# These are the values printed by `pnpm db:start` (or your hosted project).
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Direct Postgres connection used by Kysely (server-only).
SUPABASE_DB_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# --- Inngest ---
# In dev, point the SDK at the local Inngest dev server (started by `pnpm dev`).
# Set to a URL (e.g. http://localhost:8288) or just "1" for auto-detection.
INNGEST_DEV="1"
# Production keys (leave blank in dev).
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- OAuth ---
# GitHub credentials for Supabase Auth (referenced from supabase/config.toml).
# Leave blank to disable GitHub sign-in.
SUPABASE_AUTH_GITHUB_CLIENT_ID=""
SUPABASE_AUTH_GITHUB_SECRET=""

# --- LLM providers ---
# /api/chat uses Anthropic; ANTHROPIC_API_KEY is required for it.
ANTHROPIC_API_KEY=""
# OpenAI — embeddings for document indexing (text-embedding-3-small)
OPENAI_API_KEY=""

# --- Local dev auth backdoor ---
# Set to "1" ONLY for local development or E2E. When enabled, exposes
# /api/dev/login which accepts an email and mints a session without OAuth.
# NEVER set this in any deployed environment.
DEV_AUTH_ENABLED=""
