# --- Supabase ---
# These are the values printed by `pnpm db:start` (or your hosted project).
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Direct Postgres connection used by Kysely (server-only).
SUPABASE_DB_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# --- Inngest ---
# In dev, point the SDK at the local Inngest dev server (started by `pnpm dev`).
# Set to a URL (e.g. http://localhost:8288) or just "1" for auto-detection.
INNGEST_DEV="1"
# Production keys (leave blank in dev).
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- OAuth ---
# Provider credentials for Supabase Auth (referenced from supabase/config.toml).
# Leave blank to disable; sign-in attempts via that provider will fail until set.
SUPABASE_AUTH_GITHUB_CLIENT_ID=""
SUPABASE_AUTH_GITHUB_SECRET=""
SUPABASE_AUTH_GOOGLE_CLIENT_ID=""
SUPABASE_AUTH_GOOGLE_SECRET=""

# --- LLM providers ---
# /api/chat uses Anthropic; ANTHROPIC_API_KEY is required for it.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
